# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Required: Your OpenRouter API key
# Get one at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1------

# Optional: Override the model (default: google/gemini-2.0-flash-001)
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Optional: Comma-separated allowed CORS origins (default: http://localhost:5173)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR | CRITICAL  (default: INFO)
# LOG_LEVEL=INFO

# LOG_FORMAT: "text" for local dev terminal, "json" for cloud deployment
# Set to "json" in production so log aggregators (GCP, AWS, Azure) parse records correctly.
# LOG_FORMAT=text
